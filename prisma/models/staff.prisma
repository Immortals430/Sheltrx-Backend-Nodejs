model Staff {
  id              Int            @id @default(autoincrement())
  userId          Int            @unique
  aadhaarId       Int            @unique
  address         Json?
  alternateNumber String?
  comment         String?
  dob             String?
  gender          Gender
  profilePhoto    String?
  roleType        StaffRoleType?
  aadhaar         Aadhaar        @relation(fields: [aadhaarId], references: [id])
  user            User           @relation(fields: [userId], references: [id])
  hostel          Hostel[]       @relation("HostelToStaff")
}

enum StaffRoleType {
  security
  chef
  housekeeping
}
