model MealOptOut {
    id         Int @id @default(autoincrement())
    mealTypeId Int

    tenantId Int
    hostelId Int
    date     DateTime @db.Date

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    mealType MealType @relation(fields: [mealTypeId], references: [id], onDelete: Cascade)


}
