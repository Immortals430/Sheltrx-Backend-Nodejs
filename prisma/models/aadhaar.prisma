model Aadhaar {
    id               Int     @id @default(autoincrement())
    aadhaarNumber    String? @unique
    adhaarVerified   Boolean @default(false)
    adhaarTxnId      String?
    verificationDate String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    admin  Admin?
    warden Warden?
    staff  Staff?
    tenant Tenant?
}
