model MealPreference{
    id Int @id @default(autoincrement())
    tenantId Int @unique
    
    mealPack MealPack[]
    foodPlan FoodPlan[]
    allergies String?


    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    tenant Tenant @relation(fields: [tenantId], references: [userId], onDelete: Cascade)
}