model MealPreference{
    id Int @id @default(autoincrement())
    tenantId Int @unique
    
    // hostelId Int
    mealPack MealPack[]

    
    // mealType String
    // dayCategory DayCategory
    foodPlan FoodPlan[]
    allergies String?
    // isActive Boolean @default(true)   // consider it 

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    tenant Tenant @relation(fields: [tenantId], references: [userId])
    // mealPack MealPack @relation(fields: [mealPackId], references: [id])
}