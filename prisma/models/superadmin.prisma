model SuperAdmin {
  id          Int                   @id @default(autoincrement())
  userId      Int                   @unique
  roleType    SuperAdminRoleType    @default(admin)
  accessScope SuperAdminAccessScope @default(full)
  user        User                  @relation(fields: [userId], references: [id])
}

enum SuperAdminRoleType {
  admin
}

enum SuperAdminAccessScope {
  full
}
