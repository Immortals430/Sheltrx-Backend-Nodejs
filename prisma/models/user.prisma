model User {
  id          Int         @id @default(autoincrement())
  email       String      @unique
  username    String
  role        Role
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  phoneNumber String      @unique
  flag        Boolean     @default(false)
  admin       Admin?
  staff       Staff?
  superadmin  SuperAdmin?
  tenant      Tenant?
  warden      Warden?
}

enum Role {
  superadmin
  admin
  staff
  tenant
  warden
}

enum Gender {
  male
  female
  other
}
